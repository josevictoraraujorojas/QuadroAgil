<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="nota"
            type="com.example.quadroagil.data.model.Nota" />

        <variable
            name="onEditar"
            type="kotlin.jvm.functions.Function1" />

        <variable
            name="onExcluir"
            type="kotlin.jvm.functions.Function1" />
    </data>

    <androidx.cardview.widget.CardView
        android:layout_margin="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:radius="16dp">

        <LinearLayout
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtNome"
                android:text="@{nota.titulo}"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtDescricao"
                android:layout_marginTop="4dp"
                android:text="@{nota.descricao}"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Datas -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="2">

                <TextView
                    android:id="@+id/txtDataInicio"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Início: Sem data"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/txtDataFim"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Fim: Sem data"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/black"/>
            </LinearLayout>

            <!-- Spinner de status -->
            <Spinner
                android:id="@+id/spinnerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp" />

            <!-- Botões -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="8dp">

                <ImageButton
                    android:id="@+id/btnEditar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_edit"
                    android:onClick='@{() -> onEditar.invoke(nota)}'
                    android:background="@null"
                    app:tint="#6A3EC1"/>

                <ImageButton
                    android:id="@+id/btnExcluir"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_delete"
                    android:onClick='@{() -> onExcluir.invoke(nota)}'
                    android:background="@null"
                    app:tint="#6A3EC1"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</layout>
