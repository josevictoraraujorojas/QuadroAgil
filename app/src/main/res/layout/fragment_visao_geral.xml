<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.example.quadroagil.ui.viewmodel.projeto.VisaoGeralViewModel" />
    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/white"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visão Geral"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:padding="8dp" />

            <!-- Grid ainda pode ser usado futuramente para mini-donuts ou outras visualizações -->
            <GridLayout
                android:id="@+id/gridMeses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:rowCount="3"
                android:useDefaultMargins="true"
                android:alignmentMode="alignMargins" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp">

                <!-- Agora cada TextView usa LiveData do ViewModel -->
                <TextView
                    android:id="@+id/txtAfazer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text='@{"A Fazer: " + String.valueOf(viewModel.naoIniciadas)}'
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/txtFazendo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text='@{"Fazendo: " + String.valueOf(viewModel.emAndamento)}'
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/txtFeito"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text='@{"Feito: " + String.valueOf(viewModel.concluidas)}'
                    android:textSize="16sp" />
            </LinearLayout>

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </ScrollView>
</layout>
